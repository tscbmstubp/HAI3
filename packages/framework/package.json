{
  "name": "@cyberfabric/framework",
  "version": "0.2.0-alpha.0",
  "description": "FrontX framework integrating all SDK packages with plugin architecture",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "require": "./dist/types.cjs"
    }
  },
  "files": [
    "dist",
    "CLAUDE.md",
    "llms.txt",
    "commands"
  ],
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "path-to-regexp": "^8.2.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.2"
  },
  "peerDependencies": {
    "@cyberfabric/state": "*",
    "@cyberfabric/screensets": "*",
    "@cyberfabric/api": "*",
    "@cyberfabric/i18n": "*",
    "@tanstack/query-core": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "@cyberfabric/state": {
      "optional": false
    },
    "@cyberfabric/screensets": {
      "optional": false
    },
    "@cyberfabric/api": {
      "optional": false
    },
    "@cyberfabric/i18n": {
      "optional": false
    },
    "@tanstack/query-core": {
      "optional": false
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "frontx",
    "framework",
    "plugin",
    "screenset",
    "typescript"
  ],
  "author": "Cyber Fabric",
  "license": "Apache-2.0"
}
