{
  "name": "@cyberfabric/api",
  "version": "0.2.0-alpha.0",
  "description": "API communication protocols and service registry for FrontX SDK",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "require": "./dist/types.cjs"
    }
  },
  "files": [
    "dist",
    "CLAUDE.md",
    "llms.txt",
    "commands"
  ],
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {},
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "axios": "1.14.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.2",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "axios": ">=1.0.0 <1.14.1"
  },
  "sideEffects": true,
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "frontx",
    "api",
    "rest",
    "sse",
    "typescript"
  ],
  "author": "Cyber Fabric",
  "license": "Apache-2.0"
}
