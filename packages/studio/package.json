{
  "name": "@cyberfabric/studio",
  "version": "0.2.0-alpha.0",
  "description": "FrontX Studio - Development studio overlay for FrontX applications",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "./src/i18n/index.ts",
    "./dist/i18n/index.js",
    "./dist/i18n/index.cjs"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "keywords": [
    "frontx",
    "studio",
    "development",
    "react"
  ],
  "author": "Cyber Fabric",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/cyberfabric/frontx.git",
    "directory": "packages/studio"
  },
  "bugs": {
    "url": "https://github.com/cyberfabric/frontx/issues"
  },
  "homepage": "https://github.com/cyberfabric/frontx#readme",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lodash": "^4.18.1",
    "tailwind-merge": "^2.6.0"
  },
  "peerDependencies": {
    "@cyberfabric/react": "*",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.24",
    "@types/node": "^24.9.1",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "tsup": "^8.5.0",
    "typescript": "^5.4.2"
  }
}
