{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./configs/tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@/app/*": ["./src/app/*"],
      "@/screensets/*": ["./src/screensets/*"],
      "@cyberfabric/state": ["../../../state/src/index.ts"],
      "@cyberfabric/state/*": ["../../../state/src/*"],
      "@cyberfabric/layout": ["../../../layout/src/index.ts"],
      "@cyberfabric/layout/*": ["../../../layout/src/*"],
      "@cyberfabric/api": ["../../../api/src/index.ts"],
      "@cyberfabric/api/*": ["../../../api/src/*"],
      "@cyberfabric/i18n": ["../../../i18n/src/index.ts"],
      "@cyberfabric/i18n/*": ["../../../i18n/src/*"],
      "@cyberfabric/screensets": ["../../../screensets/src/index.ts"],
      "@cyberfabric/screensets/*": ["../../../screensets/src/*"],
      "@cyberfabric/framework": ["../../../framework/src/index.ts"],
      "@cyberfabric/framework/*": ["../../../framework/src/*"],
      "@cyberfabric/react": ["../../../react/src/index.ts"],
      "@cyberfabric/react/*": ["../../../react/src/*"],
      "@cyberfabric/studio": ["../../../studio/src/index.ts"],
      "@cyberfabric/studio/*": ["../../../studio/src/*"],
      "@cyberfabric/cli": ["../../src/index.ts"],
      "@cyberfabric/cli/*": ["../../src/*"]
    }
  },
  "include": ["src", "template-themes.stub.d.ts"]
}
